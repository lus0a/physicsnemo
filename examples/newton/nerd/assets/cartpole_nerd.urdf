<robot name="nerd_cartpole">
  <link name="slide_bar">
    <visual>
      <geometry>
        <box size="8 0.05 0.05"/>
      </geometry>
    </visual>
  </link>

  <link name="cart">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.2"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.5 0.5 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Realized collision-density inertia, including body armature. -->
      <mass value="50"/>
      <inertia ixx="1.2183334" ixy="0" ixz="0" iyy="1.2183334" iyz="0" izz="2.0933332"/>
    </inertial>
  </link>

  <joint name="slider_to_cart" type="prismatic">
    <parent link="slide_bar"/>
    <child link="cart"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000" lower="-4" upper="4" velocity="100"/>
  </joint>

  <link name="pole">
    <visual>
      <origin xyz="0 0 0.5"/>
      <geometry>
        <box size="0.05 0.05 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.5"/>
      <geometry>
        <box size="0.05 0.05 1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.5"/>
      <!-- Realized collision-density inertia, including body armature. -->
      <mass value="2.5"/>
      <inertia ixx="0.21885417" ixy="0" ixz="0" iyy="0.21885417" iyz="0" izz="0.01104167"/>
    </inertial>
  </link>

  <joint name="cart_to_pole" type="continuous">
    <parent link="cart"/>
    <child link="pole"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="5"/>
  </joint>
</robot>
